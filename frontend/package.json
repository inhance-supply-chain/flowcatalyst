{
	"name": "@flowcatalyst/platform-frontend",
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.27.0",
	"scripts": {
		"dev": "vite",
		"dev:full": "concurrently -k -n rust,vite -c blue,green \"cd .. && FC_API_PORT=${FC_API_PORT:-8080} FC_DATABASE_URL=${FC_DATABASE_URL:-postgresql://flowcatalyst:flowcatalyst@localhost:5432/flowcatalyst} cargo watch -w crates -w bin -x 'run --bin fc-dev'\" \"wait-on tcp:${FC_API_PORT:-8080} && VITE_BACKEND_PORT=${FC_API_PORT:-8080} vite\"",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"api:generate": "openapi-ts",
		"api:generate:live": "OPENAPI_LIVE=true openapi-ts",
		"lint": "oxlint .",
		"format": "oxfmt --write .",
		"test": "vitest",
		"test:ui": "vitest --ui"
	},
	"dependencies": {
		"@primeuix/themes": "^2.0.3",
		"@simplewebauthn/browser": "^13.3.0",
		"@vee-validate/zod": "^4.15.1",
		"fflate": "^0.8.2",
		"mermaid": "^11.4.0",
		"pinia": "^3.0.0",
		"primeicons": "^7.0.0",
		"primevue": "^4.5.4",
		"swagger-ui-dist": "^5.32.5",
		"vee-validate": "^4.15.1",
		"vue": "^3.5.13",
		"vue-router": "^4.5.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@flowcatalyst/schema-codegen": "file:packages/schema-codegen",
		"@hey-api/openapi-ts": "^0.93.1",
		"@primevue/auto-import-resolver": "^4.5.4",
		"@types/node": "^22.0.0",
		"@vitejs/plugin-vue": "^5.2.3",
		"@vitest/ui": "^4.0.18",
		"chokidar": "^4.0.0",
		"concurrently": "^9.1.0",
		"oxfmt": "^0.28.0",
		"oxlint": "^1.43.0",
		"typescript": "~5.8.0",
		"unplugin-vue-components": "^31.0.0",
		"vite": "^7.0.0",
		"vitest": "^4.0.18",
		"vue-tsc": "^2.2.0",
		"wait-on": "^8.0.0"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
